HUBSPOT_ACCESS_TOKEN=
ALLOWED_ORIGIN=https://move.jwillsoldit.com

# Optional — instant lead alert email via Resend (https://resend.com)
RESEND_API_KEY=
LEAD_ALERT_TO=
LEAD_ALERT_FROM=Smart Move Leads <onboarding@resend.dev>

# ─── Rental Verification & Invoicing module (/admin, /forms) ───
# Required: the shared password Joey signs into /admin with.
ADMIN_PASSWORD=

# Required for production: Vercel KV (Storage → KV in the Vercel dashboard).
# Verification files, links, and invoices are stored here. Without this set,
# the module falls back to a local JSON file for development only — it does
# NOT persist on Vercel's production runtime.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional — recommended. Encrypts verification link tokens at rest so the
# admin can re-display an already-issued link. Falls back to deriving a key
# from ADMIN_PASSWORD if unset (fine to start, but set a dedicated value in
# production).
TOKEN_ENCRYPTION_KEY=
