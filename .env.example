HUBSPOT_ACCESS_TOKEN=
ALLOWED_ORIGIN=https://move.jwillsoldit.com

# Optional — instant lead alert email via Resend (https://resend.com)
RESEND_API_KEY=
LEAD_ALERT_TO=
LEAD_ALERT_FROM=Smart Move Leads <onboarding@resend.dev>

# ─── Rental Verification & Invoicing module (/admin, /forms) ───
# Required: the shared password Joey signs into /admin with.
ADMIN_PASSWORD=

# Strongly recommended: turns on two-factor sign-in for /admin. When set, a
# correct password also requires a 6-digit code emailed to this address
# (sent via the Resend vars above — those must be configured too, or sign-in
# fails closed rather than silently skipping 2FA). Leave empty for
# password-only sign-in (fine for local dev).
ADMIN_2FA_EMAIL=

# Required for production: Supabase or Vercel KV. Supabase is preferred for
# the first build because it stores the admin module's JSON state in Postgres.
# Use the Project URL and service-role key from Supabase; never expose the
# service-role key in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional override; defaults to smart_move_store.
SUPABASE_STORE_TABLE=

# Legacy/alternate production backend: Vercel KV (Storage → KV in the Vercel
# dashboard). Used only if Supabase env vars are not set.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional — recommended. Encrypts verification link tokens at rest so the
# admin can re-display an already-issued link. Falls back to deriving a key
# from ADMIN_PASSWORD if unset (fine to start, but set a dedicated value in
# production).
TOKEN_ENCRYPTION_KEY=
