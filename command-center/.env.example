# Supabase (project: command-center / gsxkavelomibgjihukne)
NEXT_PUBLIC_SUPABASE_URL=https://gsxkavelomibgjihukne.supabase.co
# Publishable (anon) key. Safe to expose to the browser; RLS protects the data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. From Supabase dashboard: Project Settings > API > service_role.
# Used ONLY by /api/capture. Never exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Long random string. The iPhone Shortcut sends this as a Bearer token.
# Generate with: openssl rand -hex 32
CAPTURE_TOKEN=

# Phase 2 (not used yet): Anthropic API key for /api/brief, /api/triage, /api/friday
# ANTHROPIC_API_KEY=
